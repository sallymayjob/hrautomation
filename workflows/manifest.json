{
  "display_information": {
    "name": "New Hire Intake Automation",
    "description": "Outbound-only workflow app for new-hire intake and spreadsheet routing.",
    "background_color": "#2C2D30"
  },
  "features": {
    "bot_user": {
      "display_name": "New Hire Intake Bot",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/onboarding-status",
        "description": "Read-only onboarding status lookup by employee name",
        "url": "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec",
        "usage_hint": "<new hire name>",
        "should_escape": false
      },
      {
        "command": "/it-onboarding-status",
        "description": "IT-focused onboarding status lookup by employee name",
        "url": "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec",
        "usage_hint": "<new hire name> [--share]",
        "should_escape": false
      },
      {
        "command": "/finance-onboarding-status",
        "description": "Finance-focused onboarding status lookup by employee name",
        "url": "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec",
        "usage_hint": "<new hire name> [--share]",
        "should_escape": false
      },
      {
        "command": "/hr-onboarding-status",
        "description": "HR-focused onboarding status lookup by employee name",
        "url": "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec",
        "usage_hint": "<new hire name> [--share]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "chat:write.public",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
